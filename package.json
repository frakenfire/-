{
  "name": "tomorrow-note",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "내일쪽지 뽑기 — 토스 앱인토스용 무비용 가벼운 운세 쪽지 미니앱 MVP",
  "scripts": {
    "dev": "vite",
    "build": "ait build",
    "build:web": "tsc -b && vite build",
    "deploy": "ait deploy",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "node --experimental-strip-types --test 'src/**/*.test.ts'",
    "check:release": "node scripts/check-release-ready.mjs",
    "verify": "npm run typecheck && npm run test && npm run build:web"
  },
  "dependencies": {
    "@apps-in-toss/web-framework": "^2.10.5",
    "pretendard": "^1.3.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
